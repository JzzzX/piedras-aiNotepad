generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id                    String                 @id @default(uuid())
  name                  String
  description           String                 @default("")
  icon                  String                 @default("folder")
  color                 String                 @default("#94a3b8")
  sortOrder             Int                    @default(0)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  meetings              Meeting[]
  folders               Folder[]
  customVocabularyTerms CustomVocabularyTerm[]
}

model Meeting {
  id            String   @id @default(uuid())
  title         String   @default("")
  date          DateTime @default(now())
  status        String   @default("idle")
  duration      Int      @default(0)
  audioMimeType String?
  audioDuration Int?
  audioUpdatedAt DateTime?
  userNotes     String   @default("")
  enhancedNotes String   @default("")
  speakers      String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  folderId      String?
  workspaceId   String

  segments     TranscriptSegment[]
  chatMessages ChatMessage[]
  folder       Folder?             @relation(fields: [folderId], references: [id], onDelete: SetNull)
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Folder {
  id          String    @id @default(uuid())
  name        String
  color       String    @default("#94a3b8")
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspaceId String

  meetings  Meeting[]
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model TranscriptSegment {
  id        String  @id @default(uuid())
  speaker   String
  text      String
  startTime Float
  endTime   Float
  isFinal   Boolean @default(true)
  order     Int     @default(0)

  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id         String  @id @default(uuid())
  role       String
  content    String
  timestamp  Float
  templateId String?

  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model PromptTemplate {
  id          String   @id @default(uuid())
  name        String
  command     String   @unique
  icon        String   @default("📝")
  description String
  prompt      String
  category    String   @default("记录")
  isSystem    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CustomVocabularyTerm {
  id          String    @id @default(uuid())
  term        String
  scope       String
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([scope, workspaceId, term])
  @@index([scope, workspaceId])
}

model AsrVocabularySyncState {
  id                String   @id
  remoteVocabularyId String?
  contentHash       String   @default("")
  lastSyncedAt      DateTime?
  lastError         String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
