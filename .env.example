# ASR 模式（browser | aliyun）
ASR_MODE=browser

# 阿里云 ASR 配置
ALICLOUD_ACCESS_KEY_ID=your_access_key_id
ALICLOUD_ACCESS_KEY_SECRET=your_access_key_secret
ALICLOUD_ASR_APP_KEY=your_asr_app_key
# 可选：直接使用临时 Token（Demo 联调更快；不填则使用 AK/SK 自动换取）
ALICLOUD_ASR_TOKEN=

# MiniMax API 配置
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_group_id
MINIMAX_MODEL=MiniMax-Text-01

# LLM 路由配置（默认优先 Gemini，可回退到 MiniMax）
LLM_PROVIDER=gemini
LLM_FALLBACKS=minimax
LLM_TIMEOUT_MS=25000
LLM_RETRIES=1

# Gemini API 配置
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash-lite
