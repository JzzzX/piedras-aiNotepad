# 数据库（Vercel / Prisma Postgres / Neon 等）
DATABASE_URL=postgresql://user:password@host:5432/piedras?schema=public

# ASR 模式（browser | aliyun | doubao）
ASR_MODE=browser

# 阿里云 ASR 配置
ALICLOUD_ACCESS_KEY_ID=your_access_key_id
ALICLOUD_ACCESS_KEY_SECRET=your_access_key_secret
ALICLOUD_ASR_APP_KEY=your_asr_app_key
# 可选：直接使用临时 Token（Demo 联调更快；不填则使用 AK/SK 自动换取）
ALICLOUD_ASR_TOKEN=

# OpenAI-compatible / 聚合网关配置
OPENAI_API_KEY=your_openai_compatible_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://aihubmix.com/v1
OPENAI_PATH=/chat/completions

# 豆包 ASR 代理配置
DOUBAO_ASR_APP_ID=
DOUBAO_ASR_ACCESS_TOKEN=
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
ASR_PROXY_SESSION_SECRET=
ASR_PROXY_PORT=3001
ASR_PROXY_PUBLIC_BASE_URL=https://piedras-asr.fly.dev

# MiniMax API 配置
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_group_id
MINIMAX_MODEL=MiniMax-Text-01
# 可选：是否启用 MiniMax 流式 SSE（默认 true，异常时自动降级为非流式）
MINIMAX_USE_STREAM=true

# LLM 路由配置（示例：默认优先 OpenAI-compatible，可回退到 Gemini / MiniMax）
LLM_PROVIDER=openai
LLM_FALLBACKS=gemini,minimax
LLM_TIMEOUT_MS=25000
LLM_RETRIES=1

# Gemini API 配置
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest

# 分享 Webhook（阶段4预留）
FEISHU_WEBHOOK_URL=
WECOM_WEBHOOK_URL=

# MCP 连接器（Bearer Token 鉴权）
MCP_SERVER_TOKEN=change_this_mcp_token
